SECRET_KEY=change-me-to-random

# Netease API server address (api-enhanced)
# Local dev: http://localhost:3000
# Production: https://your-api-enhanced.onrender.com
NCM_API=http://localhost:3000

# LLM for playlist analysis (OpenAI-compatible API)
# For OpenAI:    LLM_API_KEY=sk-...  (LLM_API_URL defaults to https://api.openai.com/v1)
# For Claude:    LLM_API_KEY=sk-ant-...   LLM_API_URL=https://api.anthropic.com/v1
# For Ollama:    (no key needed)          LLM_API_URL=http://localhost:11434/v1
LLM_API_KEY=
LLM_API_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
