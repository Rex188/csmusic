SECRET_KEY=change-me-to-random

# Netease API server address (api-enhanced)
# Local dev: http://localhost:3000
# Production: https://your-api-enhanced.onrender.com
NCM_API=http://localhost:3000

# LLM for playlist analysis (OpenAI-compatible API)
# OpenAI:   LLM_API_KEY=sk-...             LLM_API_URL=https://api.openai.com/v1          LLM_MODEL=gpt-4o-mini
# DeepSeek: LLM_API_KEY=sk-...             LLM_API_URL=https://api.deepseek.com/v1        LLM_MODEL=deepseek-chat
# Ollama:   (leave key blank)              LLM_API_URL=http://localhost:11434/v1          LLM_MODEL=llama3
LLM_API_KEY=
LLM_API_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Email verification (required for production — fallback to console log in dev)
# Get a free SMTP service: SendGrid, Mailgun, Brevo, or your email provider
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_FROM=noreply@yourdomain.com
# APP_URL=https://music-self.onrender.com
